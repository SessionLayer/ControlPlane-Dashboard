{
  "name": "controlplane-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SessionLayer Control Plane admin dashboard — a typed client of the OpenAPI contract.",
  "license": "GPL-3.0-only",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "generate:api": "openapi-typescript openapi/openapi.yaml --output src/api/schema.d.ts",
    "vendor-contracts": "scripts/vendor-contracts.sh",
    "vendor-contracts:check": "scripts/vendor-contracts.sh --check",
    "sbom": "cyclonedx-npm --output-format JSON --spec-version 1.6 --output-reproducible --output-file sbom.cdx.json"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "5.3.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.9.6",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  }
}
